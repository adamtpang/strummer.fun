{
  "buildCommand": "cd vibe && npm install && npm run build && cd .. && node build.mjs",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/vibe/share/compare/:idA/:idB", "destination": "/api/share/compare/:idA/:idB" },
    { "source": "/vibe/share/:spotifyId", "destination": "/api/share/:spotifyId" },
    { "source": "/vibe", "destination": "/vibe/index.html" },
    { "source": "/vibe/:path*", "destination": "/vibe/index.html" }
  ]
}
